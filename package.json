{
  "name": "obsidian-codex-workbench",
  "version": "0.1.0",
  "description": "An Obsidian plugin MVP for a Codex-style sidebar and selection-based asking.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "codex",
    "assistant"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@types/ws": "^8.18.1",
    "esbuild": "0.25.5",
    "tslib": "2.4.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "obsidian": "latest",
    "ws": "^8.20.0"
  }
}
